generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EscrowStatus {
  AWAITING_DEPOSIT
  DEPOSITED
  CONFIRMED
  REFUNDED
}
enum EventName {
  ESCROW_CREATED
  DEPOSITED
  CONFIRMED
  REFUNDED
}

model Escrows {
  id String @id
  buyer String
  seller String
  amount String
  deadline DateTime
  status EscrowStatus
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdTxHash String
  createdBlockNumber Int
  events Events[]
}

model Events {
  id String @id @default(uuid())
  escrowId String
  escrow Escrows @relation(fields: [escrowId], references: [id])
  eventName EventName
  txHash String
  blockNumber Int
  blockHash String
  logIndex Int
  data Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([txHash, logIndex])
}

model IndexerState {
  id String @id @default("singleton")
  lastIndexedBlock Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
